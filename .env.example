# Jeop3 environment template
#
# Copy this file to .env for local development and Docker Compose.
# Keep real API keys and tokens out of git.

# OpenRouter API Configuration
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# AI models to expose in the Jeop3 UI.
OR_MODELS=google/gemini-2.5-flash-lite,google/gemini-2.5-flash

# Server configuration for local development.
# Docker Compose overrides PORT to 10005.
PORT=7476

# Optional: CORS settings. Leave unset for local development unless needed.
# AI_CORS_ORIGIN=http://localhost:8345

# Optional: source parser proxy to YTV2.
# Local dev from the host can use localhost.
# Docker Compose overrides SOURCE_PARSER_BASE_URL to host.docker.internal.
SOURCE_PARSER_BASE_URL=http://localhost:6453
YTV2_API_SECRET=replace-with-local-ytv2-secret
SOURCE_PARSER_TOKEN=${YTV2_API_SECRET}

# Optional: Ollama / local models.
# Leave unset on the i9 MacBook; enable later on a stronger GPU host.
# OLLAMA_BASE_URL=http://localhost:11434/api/chat
# OLLAMA_MODELS=gemma3:12b
